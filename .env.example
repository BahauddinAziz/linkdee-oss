# ─────────────────────────────────────────────────────────────
# LinkedReach — Environment Variables
# Copy this file to .env and fill in the values before running.
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ─────────────────────────────────────────────────
# Full connection string for your PostgreSQL instance.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/linkedreach"

# ── Server ─────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Auth (JWT) ─────────────────────────────────────────────────
# Use a long, random string for each. You can generate one with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace-with-a-long-random-secret"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-secret"

# ── Encryption ─────────────────────────────────────────────────
# AES-256 key for encrypting stored Unipile access tokens.
# Must be exactly 64 hex characters (32 bytes).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="replace-with-64-character-hex-string"

# ── CORS ───────────────────────────────────────────────────────
# The URL of the frontend app (used for CORS allow-list).
FRONTEND_URL="http://localhost:5173"
